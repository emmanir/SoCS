dimensions = [128,128];
growthProb = 0.01;
lightningProb = 0.7;
T = 1000;
nbrOfTrees = zeros(T,1);
sizeOfFires = zeros(T,1);

treeGrid = initializeForest(dimensions,growthProb);
figure(1)
plotForest(treeGrid)
title('Time step: 0','FontSize',20)
axis([0 dimensions(1) 0 dimensions(2)])

for t = 1:T
    treeGrid = lightning(treeGrid,dimensions,lightningProb);
    [row,col] = find(treeGrid==2);
    if numel(row) == 1
        nbrOfTrees(t) = nnz(treeGrid);
        pos = [row,col];
        treeGrid = spreadFire(treeGrid,dimensions,pos,...
            zeros(dimensions(1),dimensions(2)));
        sizeOfFires(t) = numel(find(treeGrid==2));
        plotForest(treeGrid)
        axis([0 dimensions(1) 0 dimensions(2)])
        title(['Time step: ',num2str(t)],'FontSize',20)
        pause(0.01);
        treeGrid = burnForest(treeGrid,dimensions);
    end
    treeGrid = growForest(treeGrid,dimensions,growthProb);
    plotForest(treeGrid)
    title(['Time step: ',num2str(t)],'FontSize',20)
    axis([0 dimensions(1) 0 dimensions(2)])
    pause(0.01);
end

nbrOfTrees = nonzeros(nbrOfTrees);
sizeOfFires = nonzeros(sizeOfFires);

sizeOfSimulatedFires = zeros(numel(sizeOfFires),1);

for t = 1:numel(sizeOfFires)
    simulatedTreeGrid = simulateForest(dimensions,nbrOfTrees(t));
    [row,col] = find(simulatedTreeGrid==2);
    simulatedTreeGrid = spreadFire(simulatedTreeGrid,dimensions,...
        [row,col],zeros(dimensions));
    plotForest(
    sizeOfSimulatedFires(t) = numel(find(simulatedTreeGrid==2));
end

relFireSize = nbrOfTrees./(dimensions(1).*dimensions(2));
relSimFireSize = sizeOfSimulatedFires./(dimensions(1).*dimensions(2));

relFireSize = sort(relFireSize,'descend');
relSimFireSize = sort(relSimFireSize,'descend');

cCDF = (1:numel(relFireSize))./numel(relFireSize);

